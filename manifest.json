{
  "manifest_version": 3,
  "name": "Color Focus",
  "version": "0.1.0",
  "description": "Color-code webpage text by part of speech to support focused reading.",
  "permissions": ["activeTab", "storage"],
  "action": {
    "default_title": "Color Focus",
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "lib/compromise.min.js",
        "lib/themeDetector.js",
        "lib/textDetector.js",
        "lib/colorEngine.js",
        "content.js"
      ],
      "css": ["styles/colorfocus.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
