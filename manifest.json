{
    "manifest_version": 3,
    "name": "Color Focus",
    "version": "0.1.0",
    "description": "Color-code texts to make reading easier",
    "permissions": ["activeTab", "storage"],
    "action": {
        "default_title": "Color Focus",
        "default_popup": "popup/popup.html"
    },
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": ["<all_urls>"],
            "js": [
                "lib/compromise.min.js",
                "lib/themeDetector.js",
                "lib/textDetector.js",
                "lib/colorEngine.js",
                "content.js"
            ],
            "css": ["styles/colorfocus.css"],
            "run_at": "document_idle"
        }
    ]
}
